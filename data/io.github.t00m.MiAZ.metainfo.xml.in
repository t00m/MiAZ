<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.t00m.MiAZ</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>MiAZ</name>
  <summary>Personal Document Organizer</summary>
  <description>
    <p>Keeping family records, school files, invoices, and administrative paperwork organised is a constant challenge, especially when documents come in from many different countries and institutions.</p>
    <p>MiAZ solves this with a simple, consistent file-naming convention of seven fields: date, country, group, sender, purpose, concept, and recipient. Scan a letter, download an email attachment, drop it into your MiAZ repository, and the app guides you through naming it correctly.</p>
    <p>Key features:</p>
    <ul>
      <li>Multiple independent document repositories</li>
      <li>No database. The directory is the database</li>
      <li>Fast workspace that handles thousands of documents</li>
      <li>Powerful sidebar with filters for every field</li>
      <li>Single and mass renaming of documents</li>
      <li>Project management: group related documents into named projects</li>
      <li>Plugin system for extending functionality</li>
    </ul>
  </description>
  <categories>
    <category>Office</category>
    <category>Database</category>
  </categories>
  <developer id="io.github.t00m">
    <name>Tomás Vírseda</name>
  </developer>
  <url type="homepage">https://github.com/t00m/MiAZ</url>
  <url type="bugtracker">https://github.com/t00m/MiAZ/issues</url>
  <url type="vcs-browser">https://github.com/t00m/MiAZ</url>
  <update_contact>tomasvirseda_AT_gmail.com</update_contact>
  <content_rating type="oars-1.1" />
  <launchable type="desktop-id">io.github.t00m.MiAZ.desktop</launchable>
  <translation type="gettext">miaz</translation>
  <requires>
    <internet>offline-only</internet>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>
  <branding>
    <color type="primary" scheme_preference="light">#a9a9da</color>
    <color type="primary" scheme_preference="dark">#45457c</color>
  </branding>
