  <releases>
    <release version="0.1.25" date="2025-05-02" urgency="medium">
      <description>
        <p>Sidebar redesign, unified plugin system, performance improvements and startup fixes.</p>
        <ul>
          <li>Sidebar rebuilt with Adw.Sidebar (icon-only filter rows and resizable pane)</li>
          <li>Plugin system unified: no more system/user distinction</li>
          <li>Plugin sidebar filters now show the plugin icon</li>
          <li>Review button turns red when pending documents exist</li>
          <li>Eliminated spurious workspace updates on startup</li>
          <li>Dropdowns now show "Any country", "Any group", etc.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.25" date="2026-05-05" urgency="low" />
    <release version="0.1.8" date="2025-07-21" urgency="low" />
    <release version="0.1.7" date="2025-03-22" urgency="low" />
    <release version="0.0.48" date="2024-07-12" urgency="low" />
